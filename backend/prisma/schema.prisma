generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum NotificationType {
  transaction
  security
  system
}

enum NotificationChannel {
  push
  email
  in_app
}

model Client {
  id                     String                  @id @default(uuid())
  firstName              String
  lastName               String?
  email                  String                  @unique
  phone                  String                  @unique
  googleId               String?                 @unique
  isVerified             Boolean                 @default(false)
  profileImage           String?
  isActive               Boolean                 @default(true)
  isBiometric            Boolean                 @default(false)
  isFaceRecognition      Boolean                 @default(false)
  faceDescriptor         Json?
  emailOtp               String?
  emailOtpExpiry         DateTime?
  refreshTokens          RefreshToken[]
  devices                Device[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  wallets                Wallet[]
  transactions           Transaction[]
  budgets                Budget[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model RefreshToken {
  id           String   @id @default(uuid())
  selector     String   @unique
  verifierHash String
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Device {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deviceName   String
  platform     String
  pushToken    String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([clientId])
}

model Notification {
  id        String              @id @default(uuid())
  clientId  String
  client    Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      NotificationType
  channel   NotificationChannel
  read      Boolean             @default(false)
  data      Json?
  createdAt DateTime            @default(now())

  @@index([clientId])
}

model NotificationPreference {
  id           String  @id @default(uuid())
  clientId     String  @unique
  client       Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pushEnabled  Boolean @default(true)
  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)
}

// ── Expense Tracker Models ─────────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategorySlug {
  food
  transport
  shopping
  health
  entertainment
  travel
  groceries
  salary
  other
}

enum WalletType {
  CHECKING
  SAVINGS
  CREDIT
  CASH
}

model Wallet {
  id           String        @id @default(uuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  bank         String
  last4        String?
  color        String        @default("#2D336B")
  walletType   WalletType    @default(CHECKING)
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@index([clientId])
}

model Transaction {
  id          String          @id @default(uuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  walletId    String?
  wallet      Wallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  type        TransactionType
  category    CategorySlug
  title       String
  description String?
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @default(now())
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([clientId])
  @@index([clientId, date])
}

model Budget {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month     Int
  year      Int
  limit     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, month, year])
  @@index([clientId])
}
