1. Prisma Schema Additions
File: backend/prisma/schema.prisma

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategorySlug {
  food
  transport
  shopping
  health
  entertainment
  travel
  groceries
  salary
  other
}

enum WalletType {
  CHECKING
  SAVINGS
  CREDIT
  CASH
}

model Wallet {
  id           String        @id @default(uuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  bank         String
  last4        String?
  color        String        @default("#2D336B")
  walletType   WalletType    @default(CHECKING)
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id          String          @id @default(uuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  walletId    String?
  wallet      Wallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  type        TransactionType
  category    CategorySlug
  title       String
  description String?
  amount      Decimal         @db.Decimal(12, 2)  // always positive; type determines sign
  date        DateTime        @default(now())
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Budget {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month     Int      // 1-12
  year      Int
  limit     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, month, year])
}
Also add to Client model:

wallets      Wallet[]
transactions Transaction[]
budgets      Budget[]
