{
  "expo": {
    "name": "ABY Expense",
    "slug": "expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/light.png",
    "scheme": "expensetracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/images/logo/light.png",
        "dark": "./assets/images/logo/dark.png",
        "tinted": "./assets/images/logo/dark.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D336B",
        "foregroundImage": "./assets/images/logo/dark.png",
        "monochromeImage": "./assets/images/logo/dark.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.abyride.expensetracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo/light.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo/dark.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#2D336B",
          "dark": {
            "image": "./assets/images/logo/dark.png",
            "backgroundColor": "#131628"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ec71afa-28f9-48d1-963d-ca83673d1979"
      }
    }
  }
}
